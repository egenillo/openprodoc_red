# ============================================================
# OpenProdoc Red — External Upgrade Configuration
# ============================================================
# Copy this file to .env and edit the values to match your
# existing OpenProdoc installation.
#
# This file is used by docker-compose.yml in this folder.
# ============================================================

# ----- EXISTING OPENPRODOC CONNECTION -----
# URL of your existing OpenProdoc (as seen from inside Docker containers)
# On Windows/Mac (Docker Desktop): use host.docker.internal
# On Linux: use 172.17.0.1 or the actual host IP
# If OpenProdoc runs on a different port, change it here
OPENPRODOC_URL=http://host.docker.internal:8080

# OpenProdoc admin credentials (used to upload the CustomTask JAR)
OPD_ROOT_USER=root
OPD_ROOT_PASSWORD=admin

# ----- EXISTING OPENPRODOC DATABASE -----
# The rag-init script needs direct access to your OpenProdoc database
# to insert task definitions (event triggers and cron tasks)
OPD_POSTGRES_HOST=host.docker.internal
OPD_POSTGRES_PORT=5432
OPD_POSTGRES_DB=prodoc
OPD_POSTGRES_USER=user1
OPD_POSTGRES_PASSWORD=pass1

# ----- OPEN WEBUI (RAG Interface) -----
# This is the URL the CustomTask JAR (running inside your OpenProdoc JVM)
# will use to reach Open WebUI. Since the JAR runs on the HOST, not inside
# Docker, this must be the host-visible URL (localhost + published port).
OPENWEBUI_HOST_URL=http://localhost:8082

# Watcher admin account for Open WebUI (created automatically)
OPENWEBUI_ADMIN_EMAIL=watcher@openprodoc.local
OPENWEBUI_ADMIN_PASSWORD=12345678

# ----- AI MODELS -----
# LLM model for chat (pulled by ollama on first start)
LLM_MODEL=llama3.1:latest

# Embedding model for RAG vector search
EMBEDDING_MODEL=nomic-embed-text:latest

# ----- SYNC -----
# How often to sync users/groups from OpenProdoc to Open WebUI (minutes)
SYNC_INTERVAL_MINS=1
